{
  "name": "pymediate-docs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "mkdir -p public && cp ../scripts/benchmark.py public/benchmark.py && next build",
    "dev": "next dev",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "check": "pnpm run lint && pnpm run types:check",
    "clean": "rm -rf out .next",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.74.0",
    "postcss": "^8.5.20",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2"
  }
}