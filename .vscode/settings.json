{
  // Python configuration
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },

  // Ruff linter
  "ruff.enable": true,

  // Python interpreter - use the venv
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Testing configuration
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  // pytest.ini already sets testpaths=tests and addopts (-v, --tb=short); no need to duplicate here
  "python.testing.pytestArgs": [],

  // Test discovery
  "python.testing.autoTestDiscoverOnSaveEnabled": true,

  // Auto-activate environment
  "python.terminal.activateEnvironment": true,

  // IntelliSense
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.pytestParameters": true,
  // Exclude deliberate mypy error snippets (see CLAUDE.md) plus generated/cache dirs from
  // Pylance's own analysis, so nothing inadvertently gets indexed or squiggled.
  "python.analysis.exclude": [
    "tests/mypy/snippets/errors/**",
    "**/__pycache__",
    "**/.venv",
    "**/.mypy_cache",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "build",
    "dist",
    "site"
  ],

  // The ms-python.mypy-type-checker extension runs mypy separately from Pylance and needs its
  // own exclude setting for the deliberately type-invalid snippets (see CLAUDE.md).
  "mypy-type-checker.ignorePatterns": ["tests/mypy/snippets/errors/**"],

  // File associations
  "files.associations": {
    "*.toml": "toml",
    ".coveragerc": "ini",
    "*.ini": "ini"
  },

  // Exclude from file watcher
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/__pycache__/**": true,
    "**/.coverage": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/site/**": true,
    "**/htmlcov/**": true
  },

  // Exclude from search
  "search.exclude": {
    "**/.venv": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/uv.lock": true,
    "**/__pycache__": true,
    "**/build": true,
    "**/dist": true,
    "**/site": true,
    "**/htmlcov": true
  }
}
