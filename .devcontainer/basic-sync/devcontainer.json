{
    "name": "pymediate example: basic-sync",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
        "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {}
    },
    "postCreateCommand": "cd examples/basic-sync && uv sync",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/examples/basic-sync/.venv/bin/python"
            }
        }
    }
}
